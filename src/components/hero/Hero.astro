---
// Home hero — Option C "Minimal & Confident"
// Four scenes, each marked with a stable class for the choreography script.
// All copy is server-rendered as static content so no-JS and reduced-motion
// users see everything regardless of the timeline running.

import { getCollection } from "astro:content";

const phrases = ["RPA developer.", "AI analyst.", "Same goal."];

const projects = (
  await getCollection("projects", ({ data }) => !data.draft)
)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, 2);
---

<div data-hero>
  <!-- Scene 1: Tagline + slow zoom backdrop -->
  <section class="hero-scene-1 relative min-h-screen flex items-center" data-scene="1">
    <div
      class="hero-scene-1__backdrop pointer-events-none absolute inset-0 -z-[1] origin-center"
      aria-hidden="true"
    >
      <div
        class="absolute left-1/2 top-1/2 h-[80vmin] w-[80vmin] -translate-x-1/2 -translate-y-1/2 rounded-full blur-3xl"
        style="background: radial-gradient(circle, rgba(59,130,246,0.18) 0%, transparent 70%);"
      >
      </div>
    </div>

    <div class="mx-auto w-full max-w-4xl px-6">
      <p class="font-mono text-xs uppercase tracking-widest text-(--color-text-dim) mb-6">
        Daniel Palmer · Shoreview, MN
      </p>
      <h1
        class="hero-scene-1__tagline font-display text-5xl md:text-7xl font-semibold tracking-[-0.03em] leading-[1.05]"
      >
        I help businesses automate the work that wastes their time.
      </h1>
      <p
        class="hero-scene-1__lede mt-8 max-w-2xl text-lg text-(--color-text-muted) leading-relaxed"
      >
        Three years of RPA at Fastenal — now embedding Claude into financial workflows
        at Meraki Private Equity.
      </p>
    </div>

    <div
      class="hero-scene-1__hint pointer-events-none absolute bottom-8 left-1/2 -translate-x-1/2 font-mono text-xs uppercase tracking-widest text-(--color-text-dim)"
      aria-hidden="true"
    >
      Scroll
    </div>
  </section>

  <!-- Scene 2: Pinned phrase swap -->
  <section
    class="hero-scene-2 relative min-h-screen flex items-center justify-center px-6"
    data-scene="2"
  >
    <div class="hero-scene-2__phrases relative w-full max-w-4xl text-center">
      {
        phrases.map((phrase, i) => (
          <p
            class="hero-scene-2__phrase font-display text-5xl md:text-7xl font-semibold tracking-[-0.03em]"
            data-phrase-index={i}
          >
            {phrase}
          </p>
        ))
      }
    </div>
  </section>

  <!-- Scene 3: Giant stat -->
  <section
    class="hero-scene-3 relative min-h-screen flex flex-col items-center justify-center text-center px-6"
    data-scene="3"
  >
    <p
      class="hero-scene-3__label font-mono text-xs uppercase tracking-widest text-(--color-text-dim) mb-6"
    >
      Three years at Fastenal
    </p>
    <p
      class="hero-scene-3__stat font-display text-7xl md:text-[10rem] font-semibold tracking-[-0.03em] leading-none text-(--color-text)"
    >
      <span class="text-(--color-accent-glow)">$30M+</span>
    </p>
    <p
      class="hero-scene-3__sub mt-6 font-display text-2xl md:text-3xl font-semibold tracking-[-0.03em] text-(--color-text-muted) max-w-2xl"
    >
      saved across 100+ automations
    </p>
    <p class="hero-scene-3__caption mt-8 text-sm text-(--color-text-dim) max-w-md">
      as part of a 7-person team — my contribution was a slice of that, but the slice was real.
    </p>
  </section>

  <!-- Scene 4: Recent work tease + CTA pair -->
  <section
    class="hero-scene-4 mx-auto max-w-6xl px-6 py-32"
    data-scene="4"
  >
    <p
      class="font-mono text-xs uppercase tracking-widest text-(--color-text-dim) mb-6"
    >
      Recent work
    </p>
    <div class="hero-scene-4__grid grid gap-6 md:grid-cols-2">
      {
        projects.map((p) => (
          <a
            href={`/work/${p.id}`}
            class="hero-scene-4__card group relative block rounded-lg border border-(--color-border) bg-(--color-surface)/60 p-6 backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:border-(--color-accent-glow)"
          >
            {p.data.tech.length > 0 && (
              <p class="font-mono text-xs uppercase tracking-widest text-(--color-text-dim)">
                {p.data.tech.slice(0, 3).join(" · ")}
              </p>
            )}
            <h3 class="mt-3 font-display text-xl font-semibold tracking-[-0.03em] text-(--color-text) group-hover:text-(--color-accent-glow)">
              {p.data.title}
            </h3>
            <p class="mt-3 text-sm text-(--color-text-muted) leading-relaxed">{p.data.summary}</p>
          </a>
        ))
      }
    </div>

    <div class="hero-scene-4__ctas mt-12 flex flex-wrap gap-3">
      <a
        href="/work"
        class="rounded-md bg-(--color-accent) px-5 py-2.5 text-sm font-medium text-(--color-bg) transition-all hover:-translate-y-0.5 hover:bg-(--color-accent-glow)"
      >
        See all work
      </a>
      <a
        href="/contact"
        class="rounded-md border border-(--color-border) px-5 py-2.5 text-sm font-medium text-(--color-text-muted) transition-all hover:-translate-y-0.5 hover:border-(--color-accent-glow) hover:text-(--color-text)"
      >
        Get in touch
      </a>
    </div>
  </section>
</div>

<style>
  /* Scene 2: stack phrases on top of each other so we cross-fade in place.
     First phrase visible by default; choreography fades the others in.
     For reduced-motion / no-JS we simply show the first — the others remain
     stacked underneath and don't break the layout. */
  .hero-scene-2__phrases {
    min-height: 8rem;
  }
  .hero-scene-2__phrase {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-scene-2__phrase[data-phrase-index="0"] {
    opacity: 1;
  }
  .hero-scene-2__phrase:not([data-phrase-index="0"]) {
    opacity: 0;
  }

  /* When the choreography is disabled (reduced-motion or no-JS), reveal all
     three phrases stacked vertically instead of the cross-fade. */
  @media (prefers-reduced-motion: reduce) {
    .hero-scene-2__phrases {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      min-height: 0;
    }
    .hero-scene-2__phrase {
      position: static;
      opacity: 1;
    }
  }
</style>

<script>
  import "../../scripts/hero-choreography";
</script>
