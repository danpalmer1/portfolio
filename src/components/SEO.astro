---
export interface Props {
  title: string;
  description: string;
  /** Path or absolute URL to OG image. Resolved against Astro.site. */
  image?: string;
  /** Canonical URL override. Defaults to Astro.url. */
  canonical?: string;
  type?: "website" | "article";
  /** ISO 8601 — for article type. */
  publishedTime?: string;
  author?: string;
}

const {
  title,
  description,
  image = "/og-default.png",
  canonical,
  type = "website",
  publishedTime,
  author = "Daniel Palmer",
} = Astro.props;

const base = Astro.site ?? Astro.url.origin;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, base).toString();
const ogImageUrl = new URL(image, base).toString();
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<meta name="author" content={author} />

<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content="Daniel Palmer" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{type === "article" && <meta property="article:author" content={author} />}

<link rel="alternate" type="application/rss+xml" title="Daniel Palmer · Blog" href="/rss.xml" />
