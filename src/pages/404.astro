---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Not found — Daniel Palmer" description="That page doesn't exist.">
  <section class="py-32 text-center">
    <p class="font-mono text-xs uppercase tracking-widest text-(--color-text-dim) mb-6">
      404
    </p>
    <h1 class="font-display text-4xl md:text-6xl font-semibold tracking-[-0.03em]">
      This page wandered off.
    </h1>
    <p class="mt-6 text-(--color-text-muted)">
      The URL looked promising but nothing's there.
    </p>
    <a
      href="/"
      class="mt-10 inline-block rounded-md border border-(--color-border) px-5 py-2.5 text-sm font-medium text-(--color-text-muted) transition-all hover:-translate-y-0.5 hover:border-(--color-accent-glow) hover:text-(--color-text)"
    >
      Back to home
    </a>
  </section>
</Layout>
