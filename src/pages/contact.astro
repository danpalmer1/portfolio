---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/contact/ContactForm";
---

<Layout
  title="Contact — Daniel Palmer"
  description="Email me about automation, AI, or anything else. Replies usually within a day."
>
  <section class="mx-auto max-w-2xl">
    <p class="font-mono text-xs uppercase tracking-widest text-(--color-text-dim) mb-4">
      Contact
    </p>
    <h1 class="font-display text-4xl md:text-5xl font-semibold tracking-[-0.03em]">
      Say hello.
    </h1>
    <p class="mt-4 text-lg text-(--color-text-muted) leading-relaxed">
      The fastest way to reach me. Goes straight to my personal inbox — replies
      usually within a day or two.
    </p>

    <div class="mt-12">
      <ContactForm client:load />
    </div>
  </section>
</Layout>
