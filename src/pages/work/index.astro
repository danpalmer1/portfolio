---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const projects = (await getCollection("projects", ({ data }) => !data.draft)).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);
---

<Layout title="Work — Daniel Palmer" description="Selected automation and AI projects.">
  <section>
    <p class="font-mono text-xs uppercase tracking-widest text-(--color-text-dim) mb-4">
      Selected work
    </p>
    <h1 class="font-display text-4xl md:text-5xl font-semibold tracking-[-0.03em]">
      Things I've built that saved someone real time.
    </h1>

    <ul class="mt-12 grid gap-6 md:grid-cols-2">
      {
        projects.map((project) => (
          <li>
            <a
              href={`/work/${project.id}`}
              class="group block rounded-lg border border-(--color-border) bg-(--color-surface)/60 p-6 backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:border-(--color-accent-glow)"
            >
              {project.data.tech.length > 0 && (
                <p class="font-mono text-xs uppercase tracking-widest text-(--color-text-dim)">
                  {project.data.tech.slice(0, 3).join(" · ")}
                </p>
              )}
              <h2 class="mt-3 font-display text-xl font-semibold tracking-[-0.03em] text-(--color-text) group-hover:text-(--color-accent-glow)">
                {project.data.title}
              </h2>
              <p class="mt-3 text-sm text-(--color-text-muted) leading-relaxed">
                {project.data.summary}
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>
